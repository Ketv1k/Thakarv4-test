<!DOCTYPE html>
<html lang="en">
<head>
	<!-- Added by AVADA SEO Suite -->
	{% include 'avada-seo' %}
	<!-- /Added by AVADA SEO Suite -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }} - {{ shop.name }}</title>
  <meta name="description" content="{{ page_description | escape }}">
  {{ content_for_header }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}">
  <link rel="stylesheet" href="{{ 'theme2.css' | asset_url }}">
  <link rel="stylesheet" href="{{ 'responsive.css' | asset_url }}">


</head>
<body>

{% render 'svg-sprite' %}

<nav>
  <button class="hamburger" id="hamburger" onclick="toggleMobile()">
    <span></span><span></span><span></span>
  </button>
  <a class="logo" href="/">
    <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" class="logo-img">
  </a>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/collections/all">Shop</a></li>
    <li><a href="/pages/about-us">About Us</a></li>
    <li><a href="/pages/contact">Contact</a></li>
    <li><a href="/pages/faq">FAQ</a></li>
    <li><a href="/pages/order-tracking">Track Order</a></li>
  </ul>
  <div class="nav-actions">
    <a href="/cart" class="nav-cart" onclick="event.preventDefault();openCartDrawer();" title="Cart">
      <svg width="20" height="20" style="display:block"><use href="#ico-cart"></use></svg>
      <span class="nav-cart-badge" id="nav-cart-count">{{ cart.item_count }}</span>
    </a>
  </div>
</nav>

<div class="mobile-menu" id="mobile-menu">
  <a href="/" onclick="closeMobile()">Home</a>
  <a href="/collections/all" onclick="closeMobile()">Shop All Products</a>
  <a href="/collections/gujarati" onclick="closeMobile()">Gujarati</a>
  <a href="/collections/north-indian" onclick="closeMobile()">North Indian</a>
  <a href="/pages/about-us" onclick="closeMobile()">About Us</a>
  <a href="/pages/contact" onclick="closeMobile()">Contact</a>
  <a href="/pages/faq" onclick="closeMobile()">FAQ</a>
  <a href="/pages/order-tracking" onclick="closeMobile()">Track Order</a>
  <a href="/cart" onclick="closeMobile();openCartDrawer();event.preventDefault();">
    <svg width="16" height="16" style="display:inline-block;vertical-align:middle;margin-right:6px"><use href="#ico-cart"></use></svg>
    My Cart <span id="mobile-cart-count">({{ cart.item_count }})</span>
  </a>
  <div class="mobile-menu-footer">
    <a href="https://wa.me/918238899993?text=Hi%20Thakar%20Kitchen!%20I%20have%20a%20question." target="_blank" class="mobile-wa-btn">
      Chat on WhatsApp
    </a>
  </div>
</div></div>

<main>
  {{ content_for_layout }}
</main>

<footer>
    <div class="footer-top">
      <div>
        <div class="footer-logo" href="/">
          <img src="{{ 'logo.jpg' | asset_url }}" alt="Thakar Kitchen"/>
          <div><div class="logo-text" style="color:#fff;font-family:Cormorant Garamond,serif;font-size:1.3rem;">Thakar <span style="color:var(--gold-light)">Kitchen</span></div></div>
        </div>
        <p class="footer-desc">Dive into a world of delightful dining – where good food is simple, pure, and utterly delicious.</p>
        <div class="social-links"><a class="social-btn" href="#"><svg width="18" height="18" style="display:block;"><use href="#ico-fb"/></svg></a><a class="social-btn" href="#"><svg width="18" height="18" style="display:block;"><use href="#ico-li"/></svg></a><a class="social-btn" href="#"><svg width="18" height="18" style="display:block;"><use href="#ico-mail"/></svg></a></div>
      </div>
      <div><div class="footer-h">Quick Links</div><ul class="footer-links"><li><a href="/">Home</a></li><li><a href="/collections/all">Shop</a></li><li><a href="/pages/bundles">Bundles</a></li><li><a href="/pages/about-us">About Us</a></li><li><a href="/pages/contact">Contact</a></li><li><a href="/pages/order-tracking">Order Tracking</a></li></ul></div>
      <div><div class="footer-h">Policies</div><ul class="footer-links"><li><a href="/policies/shipping-policy">Shipping & Payment</a></li><li><a href="/policies/refund-policy">Return Policy</a></li><li><a href="/policies/privacy-policy">Privacy Policy</a></li><li><a href="/policies/terms-of-service">Terms & Conditions</a></li></ul></div>
      <div><div class="footer-h">Contact Us</div><div class="footer-contact-item"><span class="footer-contact-icon"><svg width="16" height="16" style="display:inline-block;vertical-align:middle;flex-shrink:0;color:var(--gold,#C9960C)"><use href="#ico-pin"/></svg></span><span>GIDC 304, Sanala Road, Morbi 363641</span></div><div class="footer-contact-item"><span class="footer-contact-icon"><svg width="16" height="16" style="display:inline-block;vertical-align:middle;flex-shrink:0;color:var(--gold,#C9960C)"><use href="#ico-phone"/></svg></span><span>+91 82388 99993</span></div><div class="footer-contact-item"><span class="footer-contact-icon"><svg width="16" height="16" style="display:inline-block;vertical-align:middle;flex-shrink:0;color:var(--gold,#C9960C)"><use href="#ico-clock"/></svg></span><span>Mon–Fri: 10:00 – 18:00</span></div></div>
    </div>
    <div class="footer-bottom"><span>© {{ 'now' | date: '%Y' }} Thakar Kitchen. All rights reserved.</span><span style="color:var(--gold-light);opacity:.5">✦ Made with love in Morbi, Gujarat ✦</span></div>
  </footer>

<div class="wa-float">
  <span class="wa-tooltip">Chat with us on WhatsApp</span>
  <a class="wa-btn" href="https://wa.me/918238899993?text=Hi%20Thakar%20Kitchen!%20I%20have%20a%20question%20about%20your%20products." target="_blank" rel="noopener">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
</div>

<div class="toast" id="toast"></div>

<div class="cart-overlay" id="cart-overlay" onclick="closeCartDrawer()"></div>
<div class="cart-drawer" id="cart-drawer">
  <div class="cart-header">
    <div class="cart-header-logo">
      <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" class="cart-logo-img">
      <span class="cart-logo-name">Authentic. Pure. <span style="color:var(--gold-light)">Delicious.</span></span>
    </div>
    <button class="cart-close" onclick="closeCartDrawer()">&#215;</button>
  </div>
  <div class="cart-items">
    <div id="cart-items-list"></div>
  </div>
  <div class="cart-footer" id="cart-footer" style="display:none">
    <div class="cart-coupon-wrap" id="cart-coupon-wrap">
      <div class="cart-coupon-row" id="cart-coupon-input-row">
        <input type="text" id="cart-coupon-input" class="cart-coupon-field" placeholder="Enter coupon code" autocomplete="off" style="text-transform:uppercase">
        <button type="button" class="cart-coupon-apply-btn" onclick="tkApplyCoupon()">Apply</button>
      </div>
      <div id="cart-coupon-msg" class="cart-coupon-msg" style="display:none"></div>
      <div id="cart-coupon-applied" class="cart-coupon-applied" style="display:none">
        <span id="cart-coupon-label"></span>
        <button type="button" class="cart-coupon-remove" onclick="tkRemoveCoupon()">&times; Remove</button>
      </div>
    </div>
    <div class="cart-total-row"><span>Subtotal</span><span id="cart-subtotal"></span></div>
    <div class="cart-total-row cart-discount-row" id="cart-discount-row" style="display:none"><span id="cart-discount-label">Discount</span><span id="cart-discount-amount" style="color:#1B8A42;font-weight:700"></span></div>
    <div class="cart-total-row"><span>Delivery</span><span id="cart-delivery"></span></div>
    <div class="cart-total-final"><span>Total</span><span id="cart-total-price"></span></div>
    <a href="/checkout" class="cart-checkout-btn" id="cart-checkout-btn">Proceed to Checkout</a>
    <div class="free-delivery-note" id="free-del-note"></div>
  </div>
</div>

<script src="{{ 'theme.js' | asset_url }}" defer></script>
<script src="{{ 'cart-pincode.js' | asset_url }}" defer></script>
</body>
</html>