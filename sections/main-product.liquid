  {% when 'undhiyu' %}{% assign rv1_text = 'Exactly like my mum used to make for Uttarayan. The surti papdi and raw banana are perfectly cooked — not mushy at all. Reheated in 3 minutes and tasted fresh. Ordered 6 pouches!' %}
  {% when 'bateta' %}{% assign rv1_text = 'The masala coating on the potatoes is spot on — not too dry, not too wet. Exactly the way Kathiyawadi bateta should be. Perfect with dal-rice or just roti.' %}
