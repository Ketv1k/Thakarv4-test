<script>
(function(){
  var mainBtn = document.querySelector('#product-form-main .detail-add-cart-btn');
  var stickyBar = document.getElementById('sticky-atc');
  var stickyPrice = document.querySelector('#sticky-atc .sticky-atc-price');

  // Hide native variant select if present
  var nativeSel = document.querySelector('select[name="id"]');
  if(nativeSel) nativeSel.style.display = 'none';

  // Sync hidden input to the initially-active pack-btn on page load
  var activePackBtn = document.querySelector('.pack-btn.active');
  if(activePackBtn){
    var hiddenIdInit = document.querySelector('#product-form-main [name="id"]');
    if(hiddenIdInit) hiddenIdInit.value = activePackBtn.dataset.variantId;
    if(stickyPrice) stickyPrice.textContent = activePackBtn.dataset.price;
  }

  // .pack-btn variant selection
  document.querySelectorAll('.pack-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      document.querySelectorAll('.pack-btn').forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      var vid = btn.dataset.variantId;
      var hiddenId = document.querySelector('#product-form-main [name="id"]');
      if(hiddenId && vid) hiddenId.value = vid;
      var price = btn.dataset.price;
      if(price){
        var pagePrice = document.querySelector('.product-detail-new');
        if(pagePrice) pagePrice.textContent = price;
        if(stickyPrice) stickyPrice.textContent = price;
      }
    });
  });

  // IntersectionObserver: show sticky when main ATC scrolls out of view
  if(mainBtn && stickyBar){
    new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        stickyBar.classList.toggle('visible', !e.isIntersecting);
      });
    }, {threshold: 0}).observe(mainBtn);
  }

  // sticky-atc-btn triggers main add button
  var stickyBtn = document.querySelector('.sticky-atc-btn');
  if(stickyBtn && mainBtn){
    stickyBtn.addEventListener('click', function(){ mainBtn.click(); });
  }
})();
</script>

