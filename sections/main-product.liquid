        {% assign pd = 'A thick, tangy, warmly spiced buttermilk kadhi from Kathiyawad — bolder and spicier than standard Gujarati kadhi. Comforting and aromatic. Best poured over steamed rice or khichdi.' %}
      {% when 'methi-papad' %}
        {% assign pd = 'Crispy papads cooked with fresh fenugreek, tomatoes and a sharp spice tadka — a uniquely Gujarati combination. Slightly bitter from the methi, tangy from tomatoes, and addictively crunchy. Great as a snack or with dal-rice.' %}
      {% when 'mag' %}
        {% assign pd = 'Whole green moong dal in a light, fragrant garlic-tomato gravy. Earthy, mildly spiced, slightly creamy. One of the most wholesome and easy-to-digest dishes — perfect for a light lunch or dinner.' %}
      {% when 'vaghareli-khichdi' %}
        {% assign pd = 'Comforting moong dal and rice khichdi tempered with mustard seeds, curry leaves and mild spices. Soft, wholesome, lightly salted. The ultimate comfort food — best topped with a spoonful of ghee.' %}
      {% when 'kaju-butter-masala' %}
        {% assign pd = 'Plump cashews in a velvety, mildly sweet tomato-cream gravy with whole spices. Rich, buttery and restaurant-style indulgent. Pairs beautifully with butter naan or jeera rice.' %}
      {% when 'paneer-tikka' %}
        {% assign pd = 'Firm paneer pieces in a smoky, tangy tikka masala — bold spices, capsicum, cream and a rich tomato base. Mildly hot, deeply aromatic. Best with rumali roti or steamed basmati.' %}
      {% when 'paneer-but-masala' %}
        {% assign pd = 'The classic — soft paneer cubes in a lush, creamy tomato-butter gravy. Mildly spiced, rich and indulgent with a slightly sweet finish. Goes perfectly with naan, roti or rice.' %}
      {% when 'paneer-rajwadi' %}
        {% assign pd = 'Paneer in a royal Rajwadi gravy — richer and more aromatic than standard paneer dishes, with saffron, whole spices and a creamy nut base. Mild heat, elegant flavour. Best with laccha paratha.' %}
      {% when 'mutter-paneer' %}
        {% assign pd = 'A timeless combination — soft paneer and sweet green peas in a tomato-onion masala. Medium spiced, slightly creamy, with a fresh garden flavour. Goes well with any Indian bread or rice.' %}
      {% when 'punjabi-chhole' %}
        {% assign pd = 'Robust Punjabi chickpeas in a deep, tangy, boldly spiced gravy with whole spices and dried mango. Dark, rich and intensely flavoured. Best with bhature, kulcha or steamed rice.' %}
      {% when 'dal-taraka' %}
        {% assign pd = 'Classic restaurant-style dal tadka — toor dal finished with a smoky butter-ghee tadka of cumin, garlic and dried red chilli. Warming, aromatic, slightly smoky. A perfect everyday dal with rice or roti.' %}
      {% when 'pau-bhaji' %}
        {% assign pd = 'Mumbai street-style pav bhaji — a thick, buttery mash of mixed vegetables spiced with pav bhaji masala. Tangy, spicy, deeply satisfying. Best with toasted buttered pav or as is.' %}
      {% when 'shahi-paneer' %}
        {% assign pd = 'Paneer in an indulgent, mildly sweet Mughlai-style gravy made with cream, cashews and fragrant whole spices. Delicate heat, saffron-tinged richness. Perfect for special occasions with naan or biryani rice.' %}
      {% when 'palak-paneer' %}
        {% assign pd = 'Fresh spinach puree with soft paneer cubes, mildly spiced with ginger, garlic and garam masala. Earthy, creamy, nutritious and mildly flavoured. A balanced, wholesome dish best with roti or rice.' %}
    {% endcase %}
    {% if pd != blank %}
      <div class="product-short-desc">{{ pd }}</div>
    {% endif %}
    {% if product.available %}
      <div class="stock-badge instock"><span class="dot"></span><span>In Stock &mdash; Ready to Ship</span></div>
    {% else %}
      <div class="stock-badge lowstock"><span class="dot"></span><span>Out of Stock</span></div>
    {% endif %}
    {% form 'product', product, id: 'product-form-main', data-product-title: product.title %}
      <input type="hidden" name="id" value="{{ variant.id }}">
  

    <div class="pack-selector-wrap">
      <div class="pack-selector">
        {% assign pack_first_shown = false %}
        {% for variant in product.variants %}
          {% if variant.title == "1 Pack" %}
            {% assign pack_count = 1 %}
            {% assign pack_label = "1 Pouch" %}
            {% assign pack_badge = "" %}
          {% elsif variant.title == "Pack of 2" %}
            {% assign pack_count = 2 %}
            {% assign pack_label = "Pack of 2" %}
            {% assign pack_badge = "4% OFF" %}
          {% elsif variant.title == "Pack of 3" %}
            {% assign pack_count = 3 %}
            {% assign pack_label = "Pack of 3" %}
            {% assign pack_badge = "6% OFF" %}
          {% else %}
            {% continue %}
          {% endif %}
          {% assign unit_price = variant.price | divided_by: pack_count %}
          <button type="button"
                  class="pack-btn{% unless pack_first_shown %} active{% endunless %}"
                  data-variant-id="{{ variant.id }}"
                  data-price="{{ variant.price | money }}">
            <div class="pack-btn-header">
              <span class="pack-btn-label">{{ pack_label }}</span>
              {% if pack_badge != "" %}<span class="pack-badge">{{ pack_badge }}</span>{% endif %}
            </div>
            <div class="pack-btn-price">{{ variant.price | money }}</div>
            <div class="pack-btn-unit">{{ unit_price | money }} / pouch</div>
          </button>
          {% assign pack_first_shown = true %}
        {% endfor %}
      </div>
    </div>

    <div class="product-detail-qty-row">
        <div class="detail-qty">
          <button type="button" class="qty-btn" id="qty-minus">&#8722;</button>
          <input type="number" name="quantity" id="product-qty" value="1" min="1"
                 style="width:40px;border:none;text-align:center;font-family:inherit;font-size:.95rem;font-weight:600;background:transparent;outline:none;color:var(--royal-dark,#111C4E)">
          <button type="button" class="qty-btn" id="qty-plus">&#43;</button>
        </div>
        <button type="submit" name="add" class="detail-add-cart-btn"
                {% unless product.available %}disabled{% endunless %}>
          {% if product.available %}Add to Cart{% else %}Out of Stock{% endif %}
        </button>
        <p class="atc-free-delivery">🚚 Free Delivery on orders above ₹500</p>
      </div>
    {% endform %}

<div class="sticky-atc" id="sticky-atc">
  <div class="sticky-atc-inner">
    <div class="sticky-atc-info">
      <div class="sticky-atc-title">{{ product.title | remove: 'Ready To Eat ' | truncate: 28 }}</div>
      <div class="sticky-atc-price">{{ sell_price | money }}</div>
    </div>
    <button type="button" class="sticky-atc-btn">Add to Cart</button>
  </div>
</div>

    <div class="pincode-section">
      <div class="pincode-label">
        <svg width="14" height="14" style="color:var(--gold,#C9960C);margin-right:4px;vertical-align:middle"><use href="#ico-pin"></use></svg>
        Check Delivery
      </div>
      <div class="pincode-row">
        <input class="pincode-input" id="pincode-input" type="text" maxlength="6" placeholder="Enter your 6-digit pincode">
        <button class="pincode-check-btn" type="button">Check</button>
      </div>
      <div class="pincode-result" id="pincode-result"></div>
    </div>
  </div>
</div>

<div class="pd-below">
  <div class="pd-section pd-description-section">
    <div class="pd-tabs-nav">
      <button class="pd-tab-btn active" onclick="switchPdTab('ingredients',this)">Ingredients</button>
      <button class="pd-tab-btn" onclick="switchPdTab('howto',this)">How to Prepare</button>
      <button class="pd-tab-btn" onclick="switchPdTab('shelf',this)">Storage</button>
    </div>
    <div class="pd-tab-panel active" id="pdtab-ingredients">
      <div class="ingredients-grid">
        <div class="ing-block">
          <h4>Ingredients</h4>
          <div class="ing-list">
            {% assign ing_arr = ingredients_str | split: ', ' %}
            {% assign ing_num = 0 %}
            {% for ing in ing_arr %}
              {% assign ing_clean = ing | strip %}
              {% if ing_clean != blank %}
                {% assign ing_num = ing_num | plus: 1 %}
                <div class="ing-row">
                  <span class="ing-num">{{ ing_num }}</span>
                  <span class="ing-name">{{ ing_clean }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
          <h4 style="margin-top:16px">Certifications</h4>
          <div class="ing-tags">
            <span class="ing-tag" style="background:rgba(34,139,34,.07);border-color:rgba(34,139,34,.25);color:green"><svg width="12" height="12" style="color:green;vertical-align:middle;margin-right:3px"><use href="#ico-check"></use></svg> FSSAI Certified</span>
            <span class="ing-tag" style="background:rgba(34,139,34,.07);border-color:rgba(34,139,34,.25);color:green"><svg width="12" height="12" style="color:green;vertical-align:middle;margin-right:3px"><use href="#ico-check"></use></svg> 100% Vegetarian</span>
            <span class="ing-tag" style="background:rgba(34,139,34,.07);border-color:rgba(34,139,34,.25);color:green"><svg width="12" height="12" style="color:green;vertical-align:middle;margin-right:3px"><use href="#ico-check"></use></svg> No Artificial Preservatives</span>
          </div>
        </div>
      </div>
    </div>
    <div class="pd-tab-panel" id="pdtab-howto">
      <p class="pd-howto-subtitle" style="margin-bottom:28px">Ready in minutes &mdash; two easy ways</p>
      <div class="pd-howto-methods">
        <div class="pd-method-card">
          <div class="pd-method-title">
            <div class="pd-method-icon-wrap microwave"><svg width="24" height="24" style="color:var(--royal,#1B2A6B)"><use href="#ico-microwave"></use></svg></div>
            <div><div class="pd-method-name">Microwave Method</div><div class="pd-method-time">Ready in 2&ndash;3 minutes</div></div>
          </div>
          <div class="pd-steps">
            <div class="pd-step"><div class="pd-step-num">1</div><div class="pd-step-content"><span class="pd-step-visual"><svg width="28" height="28" style="color:var(--royal,#1B2A6B)"><use href="#ico-box"></use></svg></span><div class="pd-step-title">Open the Pack</div><div class="pd-step-desc">Transfer contents into a microwave-safe bowl.</div></div></div>
            <div class="pd-step"><div class="pd-step-num">2</div><div class="pd-step-content"><span class="pd-step-visual"><svg width="28" height="28" style="color:var(--royal,#1B2A6B)"><use href="#ico-microwave"></use></svg></span><div class="pd-step-title">Microwave on High</div><div class="pd-step-desc">Heat for 2&ndash;3 minutes until piping hot.</div></div></div>
            <div class="pd-step"><div class="pd-step-num">3</div><div class="pd-step-content"><span class="pd-step-visual"><svg width="28" height="28" style="color:var(--gold,#C9960C)"><use href="#ico-spoon"></use></svg></span><div class="pd-step-title">Stir and Check</div><div class="pd-step-desc">Give it a stir. Add 30 more seconds if needed.</div></div></div>
            <div class="pd-step"><div class="pd-step-num">4</div><div class="pd-step-content"><span class="pd-step-visual"><svg width="28" height="28" style="color:var(--gold,#C9960C)"><use href="#ico-bowl"></use></svg></span><div class="pd-step-title">Serve Hot</div><div class="pd-step-desc">Enjoy with roti, naan, or steamed rice.</div></div></div>
          </div>
        </div>
        <div class="pd-method-card">
          <div class="pd-method-title">
            <div class="pd-method-icon-wrap stovetop"><svg width="24" height="24" style="color:var(--gold,#C9960C)"><use href="#ico-flame"></use></svg></div>
            <div><div class="pd-method-name">Stovetop / Hot Water</div><div class="pd-method-time">Ready in 3&ndash;5 minutes</div></div>
          </div>
          <div class="pd-steps">
            <div class="pd-step"><div class="pd-step-num">1</div><div class="pd-step-content"><span class="pd-step-visual"><svg width="28" height="28" style="color:var(--royal,#1B2A6B)"><use href="#ico-jar"></use></svg></span><div class="pd-step-title">Keep Pouch Sealed</div><div class="pd-step-desc">Do not open the pouch before heating.</div></div></div>
            <div class="pd-step"><div class="pd-step-num">2</div><div class="pd-step-content"><span class="pd-step-visual"><svg width="28" height="28" style="color:var(--gold,#C9960C)"><use href="#ico-flame"></use></svg></span><div class="pd-step-title">Boil Water</div><div class="pd-step-desc">Place sealed pouch in boiling water.</div></div></div>
            <div class="pd-step"><div class="pd-step-num">3</div><div class="pd-step-content"><span class="pd-step-visual"><svg width="28" height="28" style="color:var(--royal,#1B2A6B)"><use href="#ico-timer"></use></svg></span><div class="pd-step-title">Heat for 3&ndash;5 Min</div><div class="pd-step-desc">Let it sit in hot water for 3&ndash;5 minutes.</div></div></div>
            <div class="pd-step"><div class="pd-step-num">4</div><div class="pd-step-content"><span class="pd-step-visual"><svg width="28" height="28" style="color:var(--royal,#1B2A6B)"><use href="#ico-scissors"></use></svg></span><div class="pd-step-title">Open and Serve</div><div class="pd-step-desc">Carefully cut open and serve directly.</div></div></div>
          </div>
          <div class="pd-serve-tip">
            <span class="pd-serve-tip-icon"><svg width="20" height="20" style="color:var(--gold,#C9960C)"><use href="#ico-bulb"></use></svg></span>
            <div class="pd-serve-tip-text"><strong>Serving Tip:</strong> Best served hot with <strong>roti or rice</strong>. Garnish with fresh coriander.</div>
          </div>
        </div>
      </div>
    </div>
    <div class="pd-tab-panel" id="pdtab-shelf">
      <div class="shelf-info">
        <div class="shelf-row"><span class="shelf-icon"><svg width="20" height="20"><use href="#ico-calendar"></use></svg></span><div><div class="shelf-label">Best Before</div><div class="shelf-val">12 months from manufacture date</div></div></div>
        <div class="shelf-row"><span class="shelf-icon"><svg width="20" height="20"><use href="#ico-thermo"></use></svg></span><div><div class="shelf-label">Storage</div><div class="shelf-val">Store in a cool, dry place away from direct sunlight.</div></div></div>
        <div class="shelf-row"><span class="shelf-icon"><svg width="20" height="20"><use href="#ico-box"></use></svg></span><div><div class="shelf-label">Packaging</div><div class="shelf-val">Hygienic sealed pouch &mdash; no preservatives added</div></div></div>
        <div class="shelf-row"><span class="shelf-icon"><svg width="20" height="20"><use href="#ico-shield"></use></svg></span><div><div class="shelf-label">Quality</div><div class="shelf-val">FSSAI certified. Tested for food safety standards.</div></div></div>
      </div>
    </div>
  </div>

  <div class="pd-section pd-trust-section">
    <div class="pd-trust-grid">
      <div class="pd-trust-card"><div class="pd-trust-icon"><svg width="28" height="28" style="color:var(--gold-light,#E8B84B)"><use href="#ico-truck"></use></svg></div><div class="pd-trust-title">Delivery in 3&ndash;4 Days</div><div class="pd-trust-sub">Pan-India shipping</div></div>
      <div class="pd-trust-card"><div class="pd-trust-icon"><svg width="28" height="28" style="color:var(--gold-light,#E8B84B)"><use href="#ico-shield"></use></svg></div><div class="pd-trust-title">Free Delivery</div><div class="pd-trust-sub">On orders above &#x20b9;500</div></div>
      <div class="pd-trust-card"><div class="pd-trust-icon"><svg width="28" height="28" style="color:var(--gold-light,#E8B84B)"><use href="#ico-leaf"></use></svg></div><div class="pd-trust-title">Preservative-Free</div><div class="pd-trust-sub">No artificial additives</div></div>
      <div class="pd-trust-card"><div class="pd-trust-icon"><svg width="28" height="28" style="color:var(--gold-light,#E8B84B)"><use href="#ico-chat"></use></svg></div><div class="pd-trust-title">24/7 Support</div><div class="pd-trust-sub">Always here to help</div></div>
      <div class="pd-trust-card"><div class="pd-trust-icon"><svg width="28" height="28" style="color:var(--gold-light,#E8B84B)"><use href="#ico-lock"></use></svg></div><div class="pd-trust-title">Secure Payment</div><div class="pd-trust-sub">100% safe &amp; encrypted</div></div>
      <div class="pd-trust-card"><div class="pd-trust-icon"><svg width="28" height="28" style="color:var(--gold-light,#E8B84B)"><use href="#ico-return"></use></svg></div><div class="pd-trust-title">Easy Returns</div><div class="pd-trust-sub">Hassle-free policy</div></div>
    </div>
  </div>

  <div class="pd-section pd-related-section">
    <div class="section-header" style="margin-bottom:36px">
      <div class="section-eyebrow">You May Also Like</div>
      <h2 class="section-title">Related <em>Products</em></h2>
      <div class="section-ornament"><span class="section-ornament-line"></span><span class="section-ornament-diamond"></span><span class="section-ornament-line r"></span></div>
    </div>
    <div class="products-grid">
      {% if product.collections.first %}
        {% for rp in product.collections.first.products limit: 5 %}
          {% unless rp.handle == product.handle %}
            {% render 'product-card', product: rp %}
          {% endunless %}
        {% endfor %}
      {% else %}
        {% for rp in collections.all.products limit: 5 %}
          {% unless rp.handle == product.handle %}
            {% render 'product-card', product: rp %}
          {% endunless %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>


