{% assign compare_price = product.compare_at_price_min %}
{% assign sell_price = product.price_min %}
{% assign savings_pct = 0 %}
{% if compare_price > sell_price %}
  {% assign diff = compare_price | minus: sell_price %}
  {% assign savings_pct = diff | times: 100 | divided_by: compare_price %}
{% endif %}

<div class="pd-header">
  <div class="pd-breadcrumb">
    <a href="/" style="color:rgba(255,255,255,.35)">Home</a> &rsaquo;
    {% if product.collections.first %}
      <a href="{{ product.collections.first.url }}" style="color:rgba(255,255,255,.35)">{{ product.collections.first.title }}</a> &rsaquo;
    {% else %}
      <a href="/collections/all" style="color:rgba(255,255,255,.35)">Shop</a> &rsaquo;
    {% endif %}
    <span style="color:var(--gold-light,#E8B84B)">{{ product.title | remove: 'Ready To Eat ' }}</span>
  </div>
</div>

<div class="pd-top">
  <div class="product-gallery">
    <div class="gallery-main-wrap">
      {% if savings_pct > 0 %}<div class="gallery-badge">-{{ savings_pct }}%</div>{% endif %}
      {% if product.featured_image %}
        <img class="gallery-main-img" id="gallery-main-img"
             src="{{ product.featured_image | img_url: '800x800' }}"
             alt="{{ product.featured_image.alt | default: product.title | escape }}">
      {% endif %}
    </div>
    {% if product.images.size > 1 %}
    <div class="gallery-thumbs">
      {% for image in product.images %}
        <img class="gallery-thumb {% if forloop.first %}active{% endif %}"
             src="{{ image | img_url: '150x150' }}"
             alt="{{ image.alt | default: product.title | escape }}"
             onclick="switchGalleryImg('{{ image | img_url: '800x800' }}', this)">
      {% endfor %}
    </div>
    {% endif %}
  </div>

  <div class="pd-buy-box">
    <div class="product-detail-cat">{{ product.type }}</div>
    <h1 class="product-detail-name">{{ product.title }}</h1>
