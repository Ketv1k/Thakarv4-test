<section class="products-section">
  <div class="section-header">
    <div class="section-eyebrow">{{ section.settings.eyebrow }}</div>
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    <div class="section-ornament">
      <span class="section-ornament-line"></span>
      <span class="section-ornament-diamond"></span>
      <span class="section-ornament-line r"></span>
    </div>
  </div>
  <div class="products-grid">
    {% if section.settings.collection != blank %}
      {% assign fc_col = collections[section.settings.collection] %}
      {% if fc_col %}
        {% for product in fc_col.products limit: section.settings.limit %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% else %}
        {% for product in collections.all.products limit: section.settings.limit %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% endif %}
    {% else %}
      {% for product in collections.all.products limit: section.settings.limit %}
        {% render 'product-card', product: product %}
      {% endfor %}
    {% endif %}
  </div>
  <div class="view-all-wrap">
    <a href="/collections/all" class="btn-royal">{{ section.settings.btn_text }}</a>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Straight From Our Kitchen" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Best-Sellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "min": 4, "max": 12, "step": 2, "label": "Products to show", "default": 8 },
    { "type": "text", "id": "btn_text", "label": "Button Text", "default": "View All Products \u2192" }
  ],
  "presets": [{ "name": "Featured Collection" }]
}
{% endschema %}
