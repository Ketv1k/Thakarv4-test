<section class="why-us">
    <div class="section-header">
      <div class="section-eyebrow">Why Choose Us</div>
      <h2 class="section-title light">Made with <em>Passion</em>,<br/>Served with Pride</h2>
      <div class="section-ornament"><span class="section-ornament-line"></span><span class="section-ornament-diamond"></span><span class="section-ornament-line r"></span></div>
    </div>
    <div class="why-grid">
      <div class="why-card"><div class="why-num">01</div><div class="why-icon"><svg width="32" height="32" style="display:inline-block;vertical-align:middle;flex-shrink:0;color:var(--gold-light)"><use href="#ico-leaf"/></svg></div><div class="why-title">100% Pure Ingredients</div><div class="why-desc">We source only fresh, natural ingredients with no artificial preservatives, colors, or flavors — ever.</div></div>
      <div class="why-card"><div class="why-num">02</div><div class="why-icon"><svg width="32" height="32" style="display:inline-block;vertical-align:middle;flex-shrink:0;color:var(--gold-light)"><use href="#ico-chef"/></svg></div><div class="why-title">Traditional Recipes</div><div class="why-desc">Our dishes follow time-honored family recipes passed down through generations of Gujarati cooking.</div></div>
      <div class="why-card"><div class="why-num">03</div><div class="why-icon"><svg width="32" height="32" style="display:inline-block;vertical-align:middle;flex-shrink:0;color:var(--gold-light)"><use href="#ico-box"/></svg></div><div class="why-title">Safe & Fresh Packaging</div><div class="why-desc">Hygienically packed with modern food-safe technology to lock in freshness and nutrients.</div></div>
    </div>
  </section>

{% schema %}
{
  "name": "Why Choose Us",
  "settings": [],
  "presets": [
    {
      "name": "Why Choose Us"
    }
  ]
}
{% endschema %}
