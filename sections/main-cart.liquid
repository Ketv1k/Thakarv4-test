{% assign threshold = 50000 %}
{% assign shipping = 6000 %}
{% assign remaining = threshold | minus: cart.total_price %}
{% assign pct = cart.total_price | times: 100 | divided_by: threshold %}
{% if pct > 100 %}{% assign pct = 100 %}{% endif %}

<div style="background:#F5EDD8;min-height:100vh;padding-bottom:140px;">

  <!-- HEADER -->
  <div style="background:#fff;padding:16px 5%;border-bottom:1px solid rgba(27,42,107,.08);display:flex;align-items:center;justify-content:space-between;">
    <h1 style="font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:700;color:#111C4E;margin:0;">
      Cart
      {% if cart.item_count > 0 %}
        <span style="background:#111C4E;color:#fff;font-family:'Jost',sans-serif;font-size:.65rem;font-weight:700;padding:2px 7px;border-radius:20px;margin-left:6px;vertical-align:middle;">{{ cart.item_count }}</span>
      {% endif %}
    </h1>
    <a href="/collections/all" style="font-size:.78rem;color:#7A7A99;text-decoration:none;">&#8592; Shop More</a>
  </div>

  {% if cart.item_count == 0 %}

    <!-- EMPTY -->
    <div style="text-align:center;padding:80px 5%;">
      <div style="font-size:3rem;margin-bottom:12px;">🛒</div>
      <div style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:600;color:#111C4E;margin-bottom:8px;">Your cart is empty</div>
      <p style="color:#7A7A99;font-size:.88rem;margin-bottom:24px;">Add something delicious!</p>
      <a href="/collections/all" style="display:inline-block;background:#111C4E;color:#fff;padding:12px 28px;border-radius:4px;text-decoration:none;font-family:'Jost',sans-serif;font-weight:700;font-size:.88rem;">Browse Products</a>
    </div>

  {% else %}

    <!-- FREE DELIVERY BAR -->
    <div style="background:#fff;margin:12px 4%;border-radius:8px;padding:14px 16px;border:1px solid rgba(201,150,12,.2);">
      {% if cart.total_price >= threshold %}
        <div style="display:flex;align-items:center;gap:8px;font-family:'Jost',sans-serif;font-size:.82rem;font-weight:600;color:#16a34a;margin-bottom:8px;">
          🎉 <span>Free Delivery Unlocked!</span>
        </div>
      {% else %}
        {% assign rem_rs = remaining | divided_by: 100 %}
        <div style="display:flex;align-items:center;justify-content:space-between;font-family:'Jost',sans-serif;font-size:.78rem;color:#111C4E;margin-bottom:8px;">
          <span>🚚 Add <strong style="color:#C9960C;">&#x20b9;{{ rem_rs }}</strong> more for <strong>Free Delivery</strong></span>
          <span style="color:#7A7A99;font-size:.68rem;">FREE above &#x20b9;500</span>
        </div>
      {% endif %}
      <!-- BAR -->
      <div style="height:8px;background:rgba(27,42,107,.08);border-radius:20px;overflow:hidden;">
        <div style="height:100%;width:{{ pct }}%;background:linear-gradient(90deg,#C9960C,#E8B84B);border-radius:20px;transition:width .5s ease;"></div>
      </div>
    </div>

    <!-- ITEMS LIST -->
    <div style="margin:12px 4%;display:flex;flex-direction:column;gap:10px;">
      {% for item in cart.items %}
        <div style="background:#fff;border-radius:8px;border:1px solid rgba(27,42,107,.07);padding:12px;display:flex;gap:12px;align-items:center;">

          <!-- IMAGE -->
          <a href="{{ item.url }}" style="flex-shrink:0;">
            <img src="{{ item.image | img_url: '160x160' }}" alt="{{ item.title | escape }}" style="width:72px;height:72px;object-fit:cover;border-radius:6px;display:block;">
          </a>

          <!-- INFO -->
          <div style="flex:1;min-width:0;">
            <a href="{{ item.url }}" style="text-decoration:none;display:block;font-family:'Jost',sans-serif;font-size:.86rem;font-weight:600;color:#111C4E;line-height:1.3;margin-bottom:2px;">{{ item.title | remove: 'Ready To Eat ' }}</a>
            <div style="font-size:.7rem;color:#7A7A99;margin-bottom:5px;">300g &middot; {{ item.product.type }}</div>
            <!-- PRICE -->
            <div style="display:flex;align-items:center;gap:6px;">
              {% if item.original_price > item.final_price %}
                <span style="font-size:.72rem;color:#7A7A99;text-decoration:line-through;">{{ item.original_price | money }}</span>
              {% endif %}
              <span style="font-size:.92rem;font-weight:700;color:#111C4E;">{{ item.final_price | money }}</span>
            </div>
          </div>

          <!-- QTY + REMOVE -->
          <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px;flex-shrink:0;">
            <!-- QTY STEPPER -->
            <div style="display:flex;align-items:center;background:#F5EDD8;border-radius:4px;overflow:hidden;">
              <form action="/cart/change" method="post" style="margin:0;">
                <input type="hidden" name="id" value="{{ item.key }}">
                <button type="submit" name="quantity" value="{{ item.quantity | minus: 1 }}" style="background:none;border:none;cursor:pointer;width:30px;height:30px;font-size:1.1rem;color:#1B2A6B;font-weight:700;display:flex;align-items:center;justify-content:center;">&#8722;</button>
              </form>
              <span style="font-size:.88rem;font-weight:700;color:#111C4E;min-width:22px;text-align:center;">{{ item.quantity }}</span>
              <form action="/cart/change" method="post" style="margin:0;">
                <input type="hidden" name="id" value="{{ item.key }}">
                <button type="submit" name="quantity" value="{{ item.quantity | plus: 1 }}" style="background:none;border:none;cursor:pointer;width:30px;height:30px;font-size:1.1rem;color:#1B2A6B;font-weight:700;display:flex;align-items:center;justify-content:center;">&#43;</button>
              </form>
            </div>
            <!-- REMOVE -->
            <form action="/cart/change" method="post" style="margin:0;">
              <input type="hidden" name="id" value="{{ item.key }}">
              <button type="submit" name="quantity" value="0" style="background:none;border:none;cursor:pointer;font-size:.68rem;color:#7A7A99;text-decoration:underline;padding:0;">Remove</button>
            </form>
          </div>

        </div>
      {% endfor %}
    </div>

    <!-- STICKY CHECKOUT BAR -->
    <div id="tk-checkout-bar" style="position:fixed!important;bottom:0!important;left:0;right:0;background:#fff;border-top:2px solid rgba(27,42,107,.1);padding:12px 4%;padding-bottom:calc(12px + env(safe-area-inset-bottom, 0px));z-index:9999;box-shadow:0 -4px 20px rgba(0,0,0,.12);display:block!important;visibility:visible!important;opacity:1!important;">
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <div>
          <div style="font-size:.68rem;color:#7A7A99;font-family:'Jost',sans-serif;">Total</div>
          <div style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:700;color:#111C4E;">
            {% if cart.total_price >= threshold %}
              {{ cart.total_price | money }}
              <span style="font-size:.65rem;background:#dcfce7;color:#16a34a;padding:2px 6px;border-radius:3px;font-family:'Jost',sans-serif;font-weight:700;margin-left:4px;">FREE DELIVERY</span>
            {% else %}
              {{ cart.total_price | plus: shipping | money }}
              <span style="font-size:.65rem;color:#7A7A99;font-family:'Jost',sans-serif;font-weight:400;">(+&#x20b9;60 delivery)</span>
            {% endif %}
          </div>
        </div>
        <a href="/checkout" style="background:#111C4E;color:#fff;text-decoration:none;padding:13px 28px;border-radius:4px;font-family:'Jost',sans-serif;font-weight:700;font-size:.9rem;letter-spacing:.04em;white-space:nowrap;">
          Checkout &rarr;
        </a>
      </div>
    </div>

  {% endif %}
</div>

{% schema %}
{"name":"Cart Page","settings":[],"presets":[{"name":"Cart Page"}]}
{% endschema %}
