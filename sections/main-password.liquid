<div style="min-height:100vh;background:var(--royal-dark,#111C4E);display:flex;align-items:center;justify-content:center">
  <div style="text-align:center;color:#fff;padding:40px;max-width:420px;width:100%">
    <img src="{{ 'logo.jpg' | asset_url }}" alt="{{ shop.name }}" style="height:80px;width:auto;background:#fff;border-radius:4px;padding:6px 14px;margin-bottom:24px">
    <h1 style="font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:600;color:var(--gold-light,#E8B84B);margin-bottom:12px">{{ shop.name }}</h1>
    <p style="color:rgba(255,255,255,.6);margin-bottom:28px">We are preparing something royal for you.</p>
    {% form 'storefront_password' %}
      {% if form.errors %}<p style="color:#f87171;font-size:.82rem;margin-bottom:12px">Incorrect password. Please try again.</p>{% endif %}
      <div style="display:flex;gap:8px;justify-content:center">
        <input type="password" name="password" placeholder="Enter password" style="flex:1;max-width:240px;padding:11px 14px;background:rgba(255,255,255,.08);border:1px solid rgba(201,150,12,.3);border-radius:3px;color:#fff;font-family:inherit;font-size:.9rem;outline:none">
        <button type="submit" class="btn-royal">Enter</button>
      </div>
    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "Password Page",
  "settings": [],
  "presets": [
    {
      "name": "Password Page"
    }
  ]
}
{% endschema %}
