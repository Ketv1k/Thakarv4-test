<div class="page-header"><h1>{{ blog.title }}</h1></div>
<div style="padding:60px 8%;background:var(--cream,#FDFAF3)">
  {% for article in blog.articles %}
    <div style="margin-bottom:32px;padding-bottom:32px;border-bottom:1px solid rgba(0,0,0,.08)">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:600;color:var(--royal-dark,#111C4E);margin-bottom:8px"><a href="{{ article.url }}" style="text-decoration:none;color:inherit">{{ article.title }}</a></h2>
      <p style="color:var(--muted,#7A7A99);font-size:.82rem;margin-bottom:10px">{{ article.published_at | date: "%B %d, %Y" }}</p>
      <p>{{ article.excerpt_or_content | strip_html | truncate: 160 }}</p>
      <a href="{{ article.url }}" style="color:var(--gold,#C9960C);font-weight:600;font-size:.85rem;text-decoration:none">Read more &rarr;</a>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Blog",
  "settings": [],
  "presets": [
    {
      "name": "Blog"
    }
  ]
}
{% endschema %}
