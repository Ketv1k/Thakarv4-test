<div class="contact-hero">
  <h1>Get in <em>Touch</em></h1>
  <p>We would love to hear from you. We respond within 24 hours.</p>
</div>
<div class="contact-body">
  <div class="contact-info">
    <h3>We are Here to Help</h3>
    <div class="contact-info-item">
      <div class="contact-info-icon"><svg width="20" height="20" style="color:#fff"><use href="#ico-pin"></use></svg></div>
      <div class="contact-info-text"><h4>Address</h4><p>GIDC 304, Sanala Road, Morbi 363641, Gujarat</p></div>
    </div>
    <div class="contact-info-item">
      <div class="contact-info-icon"><svg width="20" height="20" style="color:#fff"><use href="#ico-phone"></use></svg></div>
      <div class="contact-info-text"><h4>Phone</h4><p>+91 82388 99993</p></div>
    </div>
    <div class="contact-info-item">
      <div class="contact-info-icon"><svg width="20" height="20" style="color:#fff"><use href="#ico-mail"></use></svg></div>
      <div class="contact-info-text"><h4>Email</h4><p>support@thakarkitchen.com</p></div>
    </div>
    <div class="contact-info-item">
      <div class="contact-info-icon"><svg width="20" height="20" style="color:#fff"><use href="#ico-clock"></use></svg></div>
      <div class="contact-info-text"><h4>Hours</h4><p>Mon&ndash;Fri: 10:00 AM &ndash; 6:00 PM</p></div>
    </div>
  </div>
  <div class="contact-form-wrap">
    <h3>Send Us a Message</h3>
    {% form 'contact' %}
      {% if form.posted_successfully? %}
        <div class="contact-success show">Your message has been sent! We will get back to you within 24 hours.</div>
      {% else %}
        {% if form.errors %}
          <div style="background:rgba(155,28,28,.07);border:1px solid rgba(155,28,28,.2);border-radius:3px;padding:10px 14px;margin-bottom:16px;font-size:.82rem;color:#9B1C1C">{{ form.errors | default_errors }}</div>
        {% endif %}
        <div class="form-row">
          <div class="form-group"><label>Your Name</label><input type="text" name="contact[name]" placeholder="Ravi Patel" required></div>
          <div class="form-group"><label>Email</label><input type="email" name="contact[email]" placeholder="ravi@email.com" required></div>
        </div>
        <div class="form-group">
          <label>Subject</label>
          <select name="contact[body_subject]">
            <option value="">Select a topic</option>
            <option>Order Issue</option>
            <option>Product Inquiry</option>
            <option>Feedback</option>
            <option>Wholesale / Bulk Order</option>
            <option>Other</option>
          </select>
        </div>
        <div class="form-group"><label>Message</label><textarea name="contact[body]" placeholder="Tell us how we can help..." style="min-height:120px" required></textarea></div>
        <button type="submit" class="send-msg-btn">Send Message &rarr;</button>
      {% endif %}
    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "Contact Page",
  "settings": [],
  "presets": [
    {
      "name": "Contact Page"
    }
  ]
}
{% endschema %}
